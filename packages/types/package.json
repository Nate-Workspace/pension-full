{
    "name": "@repo/types",
    "version": "0.0.0",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build":"tsc",
        "dev": "tsc -w",
        "lint": "eslint --max-warnings 0",
        "check-types": "tsc --noEmit"
    },
    "exports":{
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        }
    },
    "devDependencies": {
        "@repo/eslint-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^22.15.3",
        "@types/eslint": "9.6.1",
        "eslint": "^9.39.1",
        "typescript": "5.9.2"
    }
}